# これは「見本」です。実際の接続情報は secrets.toml に書きます（Gitにはコミットしない）。
#
# ▼ ローカルで使う場合
#   何も設定しなくてOK。自動的に SQLite（workouts.db）が使われます。
#
# ▼ クラウド（Streamlit Community Cloud）で使う場合
#   Supabase の Session pooler 接続文字列を設定します。
#
# DATABASE_URL = "postgresql://postgres.xxxx:あなたのパスワード@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"
